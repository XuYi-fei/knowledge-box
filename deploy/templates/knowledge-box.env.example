# Copy to config/knowledge-box.env before startup
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

DB_URL=jdbc:postgresql://127.0.0.1:5432/knowledge_box
DB_USERNAME=knowledge_box
DB_PASSWORD=change-me

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=

DASHSCOPE_API_KEY=
DASHSCOPE_CHAT_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3

MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
KB_MAIL_FROM_ADDRESS=
KB_MAIL_FROM_PERSONAL=Knowledge Box

KB_ADMIN_USERNAME=admin
KB_ADMIN_PASSWORD=change-this-admin-password
KB_AUTH_JWT_SECRET=replace-with-a-long-random-jwt-secret
KB_INTEGRATION_CRYPTO_MASTER_KEY=replace-with-a-long-random-master-key

KB_STORAGE_PROVIDER=local
KB_STORAGE_LOCAL_BASE_PATH=./app/uploads
KB_STORAGE_PUBLIC_BASE_URL=https://www.xuyifei.site/uploads

KB_DOCUMENT_BOOTSTRAP_ENABLED=true
KB_DOCUMENT_BOOTSTRAP_SEED_DIRECTORY=./tmp/yuque-batch/bootstrap-seeds
KB_DOCUMENT_BOOTSTRAP_SEED_DIRECTORY_PATTERN=*.seed.json
KB_DOCUMENT_BOOTSTRAP_SEED_DIRECTORY_RECURSIVE=true
KB_DOCUMENT_BOOTSTRAP_FAIL_FAST=false
KB_DOCUMENT_BOOTSTRAP_OPERATOR_USERNAME=admin

JAVA_OPTS="-Xms512m -Xmx1536m -XX:MaxMetaspaceSize=320m -XX:+UseG1GC -XX:MaxGCPauseMillis=200"
