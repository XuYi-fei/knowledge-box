{
  "schemaVersion": "knowledge-box.config-bundle.v2",
  "tools": [
    {
      "code": "sample-tool",
      "name": "Sample Tool",
      "className": "com.example.tools.SampleTool",
      "beanName": null,
      "configJson": "{}",
      "runtimeEnvRequirements": [],
      "enabled": true
    }
  ],
  "mcpServers": [
    {
      "code": "sample-mcp",
      "transportType": "sse",
