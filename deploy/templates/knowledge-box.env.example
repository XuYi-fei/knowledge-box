# Copy to config/knowledge-box.env before startup
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

DB_URL=jdbc:postgresql://127.0.0.1:5432/knowledge_box
DB_USERNAME=xuyifei
DB_PASSWORD=

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DATABASE=0
REDIS_PASSWORD=

DASHSCOPE_API_KEY=
DASHSCOPE_CHAT_MODEL=qwen-max
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
KB_TAVILY_API_KEY=

MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
KB_MAIL_FROM_ADDRESS=
KB_MAIL_FROM_PERSONAL=小灰飞

KB_ADMIN_USERNAME=admin
KB_ADMIN_PASSWORD=
KB_AUTH_JWT_SECRET=
KB_INTEGRATION_CRYPTO_MASTER_KEY=

KB_STORAGE_PROVIDER=oss
KB_STORAGE_LOCAL_BASE_PATH=/home/ubuntu/repos/knowledge-box/uploads
KB_STORAGE_PUBLIC_BASE_URL=https://www.xuyifei.site/uploads
KB_STORAGE_OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
KB_STORAGE_OSS_BUCKET=knowledge-box
KB_STORAGE_OSS_ACCESS_KEY_ID=
KB_STORAGE_OSS_ACCESS_KEY_SECRET=
KB_STORAGE_OSS_PUBLIC_BASE_URL=https://knowledge-box.oss-cn-hangzhou.aliyuncs.com
KB_STORAGE_OSS_PATH_PREFIX=knowledge-box

KB_DOCUMENT_BOOTSTRAP_ENABLED=true
KB_DOCUMENT_BOOTSTRAP_SEED_DIRECTORY=/home/ubuntu/repos/knowledge-box/tmp/yuque-batch/bootstrap-seeds
KB_DOCUMENT_BOOTSTRAP_SEED_DIRECTORY_PATTERN=*.seed.json
KB_DOCUMENT_BOOTSTRAP_SEED_DIRECTORY_RECURSIVE=true
KB_DOCUMENT_BOOTSTRAP_FAIL_FAST=false
KB_DOCUMENT_BOOTSTRAP_OPERATOR_USERNAME=admin

KB_AGENT_BOOTSTRAP_ENABLED=true
KB_AGENT_BOOTSTRAP_SEED_FILE=/home/ubuntu/repos/knowledge-box/backend/bootstrap/config-bundle.web-search.json
KB_AGENT_BOOTSTRAP_SEED_DIRECTORY=
KB_AGENT_BOOTSTRAP_SEED_DIRECTORY_PATTERN=*.json
KB_AGENT_BOOTSTRAP_SEED_DIRECTORY_RECURSIVE=true
KB_AGENT_BOOTSTRAP_FAIL_FAST=true
KB_AGENT_BOOTSTRAP_OPERATOR_USERNAME=admin

KB_AGENT_RUNTIME_ENV_CHECK_ENABLED=true
KB_AGENT_RUNTIME_ENV_CHECK_FAIL_FAST=false
KB_AGENT_RUNTIME_ENV_CHECK_CHECK_UNPUBLISHED=true
KB_AGENT_RUNTIME_ENV_CHECK_INCLUDE_INLINE=true
KB_AGENT_RUNTIME_ENV_CHECK_REQUIRED_PROCESS_ENV_KEYS=KB_TAVILY_API_KEY,DASHSCOPE_API_KEY

JAVA_OPTS="-Xms512m -Xmx1536m -XX:MaxMetaspaceSize=320m -XX:+UseG1GC -XX:MaxGCPauseMillis=200"
