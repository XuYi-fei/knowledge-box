      "checksumMd5": null,
      "ossObjectKey": null,
      "packageLocation": "classpath:bootstrap/skills/sample-skill",
      "runtimeEnvRequirements": [],
      "enabled": true
    }
  ],
  "agents": [
    {
      "profileCode": "default-main",
