[Unit]
Description=Knowledge Box Backend
After=network.target postgresql.service redis.service

[Service]
Type=simple
User=knowledgebox
Group=knowledgebox
WorkingDirectory=/opt/knowledge-box
ExecStart=/opt/knowledge-box/deploy/start-backend.sh
ExecStop=/opt/knowledge-box/deploy/stop-backend.sh
Restart=always
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
